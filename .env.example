# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Autenticação ──────────────────────────────────────────────────────────────
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_chave_secreta_longa_e_aleatoria

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://seu-frontend.vercel.app
API_URL=https://seu-backend.onrender.com

# ── Cloudinary (upload de imagens) ────────────────────────────────────────────
# Crie conta gratuita em https://cloudinary.com
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── Resend (envio de e-mails) ─────────────────────────────────────────────────
# Crie conta em https://resend.com — plano gratuito: 3000 emails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remetente — precisa ser um domínio verificado no Resend
FROM_EMAIL=Mesafay <noreply@mesafay.com.br>
# E-mail para respostas dos restaurantes
REPLY_EMAIL=contato@mesafay.com.br

# ── Deploy (EasyPanel webhook) ────────────────────────────────────────────────
EASYPANEL_WEBHOOK=https://seu-easypanel.com/webhook/deploy
